{
  "name": "typeorm-cloud-sync",
  "version": "2.0.0",
  "description": "Sync Sqlite data to Firebase Firestore",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\"",
    "test": "jest --config jestconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm test",
    "postpack": "node rename-package.js",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "files": [
    "lib/**/*"
  ],
  "peerDependencies": {
    "firebase": "^12.0.0",
    "rxjs": "^7.0.0",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "firebase": "^12.16.0",
    "jest": "^30.4.2",
    "prettier": "^3.0.0",
    "rxjs": "^7.8.2",
    "sql.js": "^1.14.0",
    "ts-jest": "^29.4.11",
    "typeorm": "^1.1.0",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "uuid": "^14.0.1"
  }
}
